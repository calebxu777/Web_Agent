# MVP provider
OPENAI_API_KEY=your-gemini-or-openai-key
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MVP_MASTER_BRAIN_MODEL=gemini-2.5-flash
MVP_ROUTER_MODEL=gemini-2.5-flash
MVP_RERANKER_MODEL=gemini-2.5-flash

# Web search
SERPAPI_API_KEY=your-serpapi-key
SERPAPI_GL=us
SERPAPI_HL=en
SERPAPI_LOCATION=

# Memory
MVP_USE_MEMORY=true

# GCS-backed MVP data
MVP_GCS_CATALOG_DB_URL=https://storage.googleapis.com/web-agent-data-caleb-2026/metadata/catalog.db
MVP_GCS_LANCEDB_PUBLIC_PREFIX=https://storage.googleapis.com/web-agent-data-caleb-2026/data/processed/lancedb
MVP_GCS_LANCEDB_MANIFEST_URL=
